# Agent Arena — client config. Copy to .env.local and fill in.
# All values are PUBLIC (NEXT_PUBLIC_*) and read-only. Never put a private key
# or the tokenized "canteen" RPC here — browser reads use the public Arc RPC.

# AgentRegistry address on Arc testnet (chain 5042002).
# Not hardcoded because the demo redeploys it each run. When unset, the arena
# renders an honest "registry not configured" state instead of mock data.
NEXT_PUBLIC_AGENT_REGISTRY=

# PerformanceOracle address — source of the leaderboard's AdviceResolved
# win/loss history. When unset, the leaderboard shows "oracle not configured".
NEXT_PUBLIC_PERFORMANCE_ORACLE=

# Colosseum address — the live-duel backbone (betting + chaos + scoring).
# Redeployed per run. When unset, /colosseum renders an honest "not configured"
# state instead of fabricating a duel.
NEXT_PUBLIC_COLOSSEUM=

# MemoryAnchor address — where agents anchor their compressed-memory roots.
# Powers the "anchored ✓" proof on the live memory panel. Redeployed per run.
NEXT_PUBLIC_MEMORY_ANCHOR=

# Optional RPC override the browser reads from. Defaults to the public Arc RPC
# (https://rpc.testnet.arc.network) when unset. Use only for a local anvil at
# chain 5042002 during full-stack testing. NEVER the tokenized canteen RPC.
NEXT_PUBLIC_RPC_URL=
