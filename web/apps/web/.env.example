# Agent Arena — client config. Copy to .env.local and fill in.
# All values are PUBLIC (NEXT_PUBLIC_*) and read-only. Never put a private key
# or the tokenized "canteen" RPC here — browser reads use the public Arc RPC.

# AgentRegistry address on Arc testnet (chain 5042002).
# Not hardcoded because the demo redeploys it each run. When unset, the arena
# renders an honest "registry not configured" state instead of mock data.
NEXT_PUBLIC_AGENT_REGISTRY=

# PerformanceOracle address — source of the leaderboard's AdviceResolved
# win/loss history. When unset, the leaderboard shows "oracle not configured".
NEXT_PUBLIC_PERFORMANCE_ORACLE=
