# AgoraHack — BACKEND config (Python runner + live launcher).
# Copy to `.env` (gitignored) and fill in. The Python entrypoints auto-load this
# file; no `export` needed. Explicit env vars / CLI flags override these.
#
# NOTE: the WEB app has its OWN env at web/apps/web/.env.local (Next.js loads it);
# this root .env is for the backend only. NEVER commit a real .env.

# ---- Model provider (the duelists make REAL LLM calls) ----------------------
# Use EITHER OpenRouter (OpenAI-compatible, routes to Claude/any model) OR the
# native Anthropic SDK. OpenRouter is the easy path if you don't have an
# Anthropic key.
OPENROUTER_API_KEY=
# Optional OpenRouter model slug. Both duelists use the SAME model (the only
# A/B difference is the defense prompt). Examples:
#   anthropic/claude-3.5-haiku   openai/gpt-4o-mini   meta-llama/llama-3.3-70b-instruct
OPENROUTER_MODEL=anthropic/claude-3.5-haiku

# Alternative provider (only if you have a native Anthropic key):
ANTHROPIC_API_KEY=

# ---- Arc chain (live runs only) ---------------------------------------------
# RPC for Arc testnet. If unset, the launcher falls back to ~/.arc-canteen/env.
# The tokenized "canteen" RPC is a SECRET — fine here (this file is gitignored),
# but never commit it and never put it in the web app's NEXT_PUBLIC_* env.
RPC=
# The duel runner reads ARENA_RPC_URL (usually the same as RPC).
ARENA_RPC_URL=

# Per-agent registration stake in USDC for the LIVE launcher. The contract
# default is 50; on a faucet budget set this low (e.g. 1) so registering both
# agents needs ~2 USDC instead of ~100. Leave empty to use the contract default.
STAKE_USDC=1

# Operator/deployer signer for live broadcasts. PREFER a Foundry keystore: set
# its name here (decrypted in-process; you'll be prompted for the password, or
# set KEYSTORE_PASSWORD). Lets `colosseum_live.sh -y` run with no long flags.
DEPLOYER_ACCOUNT=arc-deployer
# Only set a raw key instead if you accept a plaintext key in this gitignored
# file (the keystore above is safer).
DEPLOYER_PK=
